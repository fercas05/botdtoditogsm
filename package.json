{
	"name": "base-bailey-json",
	"version": "1.0.0",
	"description": "",
	"main": "dist/app.js",
	"type": "module",
	"scripts": {
		"start": "node --env-file=.env ./dist/app.js",
		"lint": "eslint . --no-ignore",
		"db": "nodemon --env-file=.env src/database/Config/init.ts",
		"dev": "nodemon --env-file=.env ./src/app.ts",
		"build": "esbuild src/app.ts --bundle --platform=node --format=esm --outfile=dist/app.js --packages=external",
		"clean:database": "tsx --env-file=.env src/scripts/cleanDatabase.ts",
		"migrate:phones": "tsx --env-file=.env src/scripts/migratePhoneNumbers.ts",
		"fix:duplicates": "tsx --env-file=.env src/scripts/removeDuplicates.ts"
	},
	"keywords": [],
	"dependencies": {
		"@builderbot/bot": "1.4.2",
		"@builderbot/database-json": "^1.4.2",
		"@builderbot/provider-baileys": "^1.4.2",
		"@gamastudio/sendwave-provider": "^1.0.5",
		"axios": "^1.18.1",
		"colors": "^1.4.0",
		"mysql2": "^3.22.5",
		"pg": "^8.22.0",
		"sequelize": "^6.37.8"
	},
	"devDependencies": {
		"@types/colors": "^1.2.4",
		"@types/node": "^20.19.43",
		"@typescript-eslint/eslint-plugin": "^7.18.0",
		"@typescript-eslint/parser": "^7.18.0",
		"esbuild": "^0.25.12",
		"eslint": "^8.57.1",
		"eslint-plugin-builderbot": "latest",
		"nodemon": "^3.1.14",
		"tsx": "^4.22.4",
		"typescript": "^5.9.3"
	},
	"author": "",
